{
  "expo": {
    "name": "Sortlist",
    "slug": "sortlist",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "sortlist",
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.alexesterkin.sortlist",
      "appleTeamId": "REPLACE_WITH_APPLE_TEAM_ID",
      "associatedDomains": [
        "applinks:sortlist.shop",
        "applinks:www.sortlist.shop"
      ],
      "entitlements": {
        "keychain-access-groups": [
          "$(AppIdentifierPrefix)com.alexesterkin.sortlist"
        ],
        "com.apple.security.application-groups": [
          "group.com.alexesterkin.sortlist"
        ]
      },
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.alexesterkin.sortlist",
      "adaptiveIcon": {
        "backgroundColor": "#FAF8F3",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-web-browser",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#FAF8F3",
          "dark": {
            "backgroundColor": "#1A1A1A"
          }
        }
      ],
      "expo-image",
      "./plugins/with-native-share-extension.js",
      [
        "expo-build-properties",
        {
          "ios": {
            "newArchEnabled": false
          }
        }
      ],
      "./plugins/withDevelopmentTeam.js"
    ],
    "experiments": {
      "typedRoutes": false
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "edb058b6-8512-424c-bb56-e65474134ba5"
      }
    }
  }
}
