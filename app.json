{
  "expo": {
    "name": "Sortlist",
    "slug": "sortlist",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "sortlist",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.alexesterkin.sortlist",
      "associatedDomains": [
        "applinks:sortlist.shop",
        "applinks:www.sortlist.shop"
      ],
      "entitlements": {
        "keychain-access-groups": [
          "$(AppIdentifierPrefix)com.alexesterkin.sortlist"
        ]
      },
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.alexesterkin.sortlist",
      "adaptiveIcon": {
        "backgroundColor": "#FAF8F3",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-web-browser",
      [
        "expo-font",
        {
          "fonts": [
            "./assets/fonts/InstrumentSerif-Regular.ttf",
            "./assets/fonts/InstrumentSerif-Italic.ttf"
          ]
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#FAF8F3",
          "dark": {
            "backgroundColor": "#1A1A1A"
          }
        }
      ],
      [
        "expo-share-extension",
        {
          "height": 540,
          "backgroundColor": {
            "red": 250,
            "green": 248,
            "blue": 243,
            "alpha": 1
          },
          "activationRules": [
            { "type": "url", "max": 1 },
            { "type": "text" }
          ],
          "excludedPackages": [
            "expo-dev-client",
            "expo-splash-screen",
            "expo-updates",
            "expo-router"
          ]
        }
      ]
    ],
    "experiments": {
      "typedRoutes": false,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "edb058b6-8512-424c-bb56-e65474134ba5"
      }
    }
  }
}
