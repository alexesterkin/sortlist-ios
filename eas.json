{
  "cli": {
    "version": ">= 18.11.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "ios": {
        "image": "macos-sonoma-14.6-xcode-16.0"
      }
    },
    "preview": {
      "distribution": "internal",
      "env": {
        "EXPO_PUBLIC_APP_VARIANT": "preview"
      },
      "ios": {
        "image": "macos-sonoma-14.6-xcode-16.0",
        "buildConfiguration": "Release"
      }
    },
    "production": {
      "autoIncrement": true,
      "env": {
        "EXPO_PUBLIC_APP_VARIANT": "production"
      },
      "ios": {
        "image": "macos-sonoma-14.6-xcode-16.0"
      }
    }
  },
  "submit": {
    "production": {}
  }
}
