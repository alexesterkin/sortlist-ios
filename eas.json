{
  "cli": {
    "version": ">= 18.11.0",
    "appVersionSource": "remote"
  },
  "experimental": {
    "ios": {
      "appExtensions": [
        {
          "targetName": "SortlistShareExtension",
          "bundleIdentifier": "com.alexesterkin.sortlist.ShareExtension"
        }
      ]
    }
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "node": "20.19.4",
      "ios": {
        "bundleIdentifier": "com.alexesterkin.sortlist",
        "image": "macos-sequoia-15.5-xcode-26.0"
      }
    },
    "preview": {
      "distribution": "internal",
      "node": "20.19.4",
      "env": {
        "EXPO_PUBLIC_APP_VARIANT": "preview"
      },
      "ios": {
        "bundleIdentifier": "com.alexesterkin.sortlist",
        "image": "macos-sequoia-15.5-xcode-26.0",
        "buildConfiguration": "Release"
      }
    },
    "production": {
      "autoIncrement": true,
      "node": "20.19.4",
      "env": {
        "EXPO_PUBLIC_APP_VARIANT": "production"
      },
      "ios": {
        "bundleIdentifier": "com.alexesterkin.sortlist",
        "image": "macos-sequoia-15.5-xcode-26.0"
      }
    }
  },
  "submit": {
    "production": {}
  }
}
